## t/test_stryke_spark_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn X::Y::name` declared in lib/*.stk is
## reachable via `use` at runtime. Uses `exists &X::Y::name` to
## probe the symbol table without invoking the sub.
##
## Catches:
##   * a wrapper sub deleted from lib/ but still referenced elsewhere
##   * a sub-package file dropped from the install layout
##   * `use Foo::Bar` failing to chase into lib/Bar.stk
##   * an installed-package entry whose namespace bridge is broken
##
## Permission-free — no service, no creds, no live daemon. Private
## helpers (`_` prefix) are implementation detail and are NOT
## asserted, so refactoring internals stays free.

use Spark

# ── Spark.stk ──────────────────────────────────────────────
assert_ok exists &Spark::version, "Spark::version exists"
assert_ok exists &Spark::ping, "Spark::ping exists"
assert_ok exists &Spark::query, "Spark::query exists"
assert_ok exists &Spark::query_one, "Spark::query_one exists"
assert_ok exists &Spark::query_col, "Spark::query_col exists"
assert_ok exists &Spark::query_scalar, "Spark::query_scalar exists"
assert_ok exists &Spark::query_stream, "Spark::query_stream exists"
assert_ok exists &Spark::dump, "Spark::dump exists"
assert_ok exists &Spark::execute, "Spark::execute exists"
assert_ok exists &Spark::explain, "Spark::explain exists"
assert_ok exists &Spark::read, "Spark::read exists"
assert_ok exists &Spark::write, "Spark::write exists"
assert_ok exists &Spark::tables, "Spark::tables exists"
assert_ok exists &Spark::databases, "Spark::databases exists"
assert_ok exists &Spark::schema, "Spark::schema exists"
assert_ok exists &Spark::columns, "Spark::columns exists"
assert_ok exists &Spark::functions, "Spark::functions exists"
assert_ok exists &Spark::cache, "Spark::cache exists"
assert_ok exists &Spark::uncache, "Spark::uncache exists"
assert_ok exists &Spark::config, "Spark::config exists"
assert_ok exists &Spark::submit, "Spark::submit exists"
assert_ok exists &Spark::count, "Spark::count exists"

# ── Spark.stk catalog introspection ──
assert_ok exists &Spark::views, "Spark::views exists"
assert_ok exists &Spark::catalogs, "Spark::catalogs exists"
assert_ok exists &Spark::current_database, "Spark::current_database exists"

assert_ok exists &Spark::create_temp_view, "Spark::create_temp_view exists"
assert_ok exists &Spark::drop_temp_view, "Spark::drop_temp_view exists"
assert_ok exists &Spark::set_database, "Spark::set_database exists"
assert_ok exists &Spark::refresh_table, "Spark::refresh_table exists"

# ── pure helpers (no session) ──
assert_ok exists &Spark::parse_master_url, "Spark::parse_master_url exists"
assert_ok exists &Spark::build_master_url, "Spark::build_master_url exists"
assert_ok exists &Spark::parse_memory, "Spark::parse_memory exists"
assert_ok exists &Spark::build_memory, "Spark::build_memory exists"
assert_ok exists &Spark::parse_table_name, "Spark::parse_table_name exists"
assert_ok exists &Spark::build_table_name, "Spark::build_table_name exists"
assert_ok exists &Spark::quote_ident, "Spark::quote_ident exists"
assert_ok exists &Spark::quote_qualified_ident, "Spark::quote_qualified_ident exists"

test_run
