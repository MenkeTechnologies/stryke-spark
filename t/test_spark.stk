## t/test_spark.stk — assertion tests for the stryke `Spark` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_spark.{dylib,so}` on
## `use Spark`. Live tests fire when `spark-submit` is on $PATH; each call
## spins a fresh JVM (~5–10s) so the suite is intentionally small.

use Spark

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Spark::version()
assert_ok $version, "Spark::version returns truthy (cdylib loaded)"

# ── spark-submit availability + live JVM probe ──────────────────────
# `command -v spark-submit` is a fast PATH check, but the JVM may still
# fail (missing JAVA_HOME, incompatible JDK, log4j init errors).
# Probe with eval to skip cleanly when the JVM can't start.
val $have_submit = system("command -v spark-submit >/dev/null 2>&1") == 0
val $alive = $have_submit && eval { Spark::ping() }

if ($alive) {
    # 1. ping
    assert_ok Spark::ping(), "ping returns truthy"

    # 2. plain SELECT
    val @rows = Spark::query("SELECT 1 + 1 AS two, 'hi' AS s")
    assert_eq scalar(@rows), 1, "simple query: 1 row"
    assert_eq $rows[0]->{two}, 2, "simple query: 1+1=2"
    assert_eq $rows[0]->{s}, "hi", "simple query: string col"

    # 3. range() table-valued fn
    val @range = Spark::query("SELECT id FROM range(5) ORDER BY id")
    assert_eq scalar(@range), 5, "range(5): 5 rows"
    assert_eq $range[4]->{id}, 4, "range(5): last row id=4"

    # 4. query_scalar
    assert_eq Spark::query_scalar("SELECT COUNT(*) AS n FROM range(10)"), 10, "query_scalar: count(range(10))=10"

    # 5. columnar
    val $cw = Spark::query("SELECT id FROM range(3)", columnar => 1)
    assert_eq ref($cw), "HASH", "columnar: returns hash"
    assert_eq $cw->{num_rows}, 3, "columnar: num_rows=3"
    assert_eq scalar(@{$cw->{rows}}), 3, "columnar: rows array"

    # 6. databases includes 'default'
    val @dbs = Spark::databases()
    val $found_default = grep { $_ eq "default" } @dbs
    assert_ok $found_default, "databases: contains 'default'"
}

# ── pure helpers (no Spark — always run) ─────────────────────────────
assert_eq Spark::parse_master_url("local[8]")->{threads}, 8, "parse_master_url: local thread count"
assert_eq Spark::parse_master_url("local[*]")->{threads}, "*", "parse_master_url: all cores"
val $ha = Spark::parse_master_url("spark://m1:7077,m2:7077")
assert_eq scalar(@{ $ha->{hosts} }), 2, "parse_master_url: HA host list"
assert_eq $ha->{hosts}[0]{port}, 7077, "parse_master_url: standalone port"
val $k = Spark::parse_master_url("k8s://https://api:6443")
assert_eq $k->{scheme}, "k8s",                "parse_master_url: k8s scheme"
assert_eq $k->{master}, "https://api:6443",   "parse_master_url: k8s inner URL"

# build_master_url: inverse of parse_master_url.
assert_eq Spark::build_master_url(scheme => "local", threads => 8), "local[8]", "build_master_url: local[8]"
assert_eq Spark::build_master_url(scheme => "local", threads => 1), "local", "build_master_url: 1 thread → bare local"
assert_eq Spark::build_master_url(scheme => "spark", hosts => [{ host => "m1", port => 7077 }, { host => "m2", port => 7077 }]), "spark://m1:7077,m2:7077", "build_master_url: standalone HA"
assert_eq Spark::build_master_url(scheme => "k8s", master => "https://api:6443"), "k8s://https://api:6443", "build_master_url: k8s inner URL"
# round-trips parse_master_url.
assert_eq Spark::build_master_url(%{ Spark::parse_master_url("local[*]") }), "local[*]", "build_master_url: round-trips local[*]"
assert_dies fn { Spark::build_master_url(scheme => "mesos") }, "build_master_url: scheme needing master errors without one"

val $cdt = Spark::parse_table_name("iceberg.analytics.events")
assert_eq $cdt->{catalog},  "iceberg",   "parse_table_name: catalog"
assert_eq $cdt->{database}, "analytics", "parse_table_name: database"
assert_eq $cdt->{table},    "events",    "parse_table_name: table"
# backtick-quoted dotted name stays in one part
val $q = Spark::parse_table_name("db.`weird.table`")
assert_eq $q->{table}, "weird.table", "parse_table_name: quoted dot stays together"

# build_table_name: inverse of parse_table_name, minimal quoting.
assert_eq Spark::build_table_name(catalog => "iceberg", database => "analytics", table => "events"), "iceberg.analytics.events", "build_table_name: clean three-level name"
assert_eq Spark::build_table_name(table => "events"), "events", "build_table_name: table only"
assert_eq Spark::build_table_name(database => "db", table => "weird.table"), "db.`weird.table`", "build_table_name: dotted segment backtick-quoted"
assert_dies fn { Spark::build_table_name(catalog => "c", table => "t") }, "build_table_name: catalog requires a database"

# parse_memory: Spark byte-string size config (binary suffixes).
val $mem = Spark::parse_memory("512m")
assert_eq $mem->{bytes}, 536870912, "parse_memory: 512m = 512 MiB in bytes"
assert_eq $mem->{mib},   512,        "parse_memory: 512m = 512 MiB"
assert_eq Spark::parse_memory("1kb")->{bytes}, 1024, "parse_memory: Spark kb is 1024 bytes (binary)"
assert_eq Spark::parse_memory("2g")->{bytes}, 2147483648, "parse_memory: 2g = 2 GiB"
assert_eq Spark::parse_memory("2GiB")->{bytes}, 2147483648, "parse_memory: 2GiB agrees with 2g (case-insensitive)"
assert_eq Spark::parse_memory("4096")->{bytes}, 4096, "parse_memory: no suffix is bytes"
assert_dies fn { Spark::parse_memory("10x") }, "parse_memory: rejects an unknown suffix"

# build_memory: inverse — encode bytes as a Spark size string.
assert_eq Spark::build_memory(0)->{string},          "0b",     "build_memory: zero is 0b"
assert_eq Spark::build_memory(2147483648)->{string}, "2g",     "build_memory: 2 GiB collapses to 2g"
assert_eq Spark::build_memory(1610612736)->{string}, "1536m",  "build_memory: 1.5 GiB drops to 1536m"
assert_eq Spark::build_memory(1234)->{string},       "1234b",  "build_memory: non-power-of-1024 falls to bytes"
assert_eq Spark::build_memory(1099511627776)->{string}, "1t",  "build_memory: largest unit wins (1 TiB → 1t)"
assert_eq Spark::parse_memory(Spark::build_memory(536870912)->{string})->{bytes}, 536870912, "build_memory: round-trips through parse_memory"
assert_dies fn { Spark::build_memory() }, "build_memory: requires bytes"

# convert_memory: re-express a size in a chosen whole unit.
assert_eq Spark::convert_memory("2g", "m")->{string},    "2048m", "convert_memory: 2g → 2048m"
assert_eq Spark::convert_memory("2048m", "g")->{string}, "2g",    "convert_memory: 2048m → 2g"
assert_eq Spark::convert_memory("1024", "k")->{string},  "1k",    "convert_memory: bare bytes → 1k"
assert_eq Spark::convert_memory("2g", "mib")->{string},  "2048m", "convert_memory: iec target emits short suffix"
assert_dies fn { Spark::convert_memory("1536m", "g") }, "convert_memory: non-whole result dies"
assert_dies fn { Spark::convert_memory("2g", "x") }, "convert_memory: unknown target suffix dies"

assert_eq Spark::quote_ident("weird`col"), "`weird``col`", "quote_ident: backticks doubled"

# unquote_ident: inverse of quote_ident (strip backticks, un-double).
assert_eq Spark::unquote_ident("`weird``col`"), "weird`col", "unquote_ident: doubled backtick decodes to one"
assert_eq Spark::unquote_ident("`plain`"),      "plain",     "unquote_ident: plain quoted name"
assert_eq Spark::unquote_ident(Spark::quote_ident("has space")), "has space", "unquote_ident: round-trips quote_ident"
assert_dies fn { Spark::unquote_ident("plain") },   "unquote_ident: rejects an unquoted name"
assert_dies fn { Spark::unquote_ident("`a`b`") },   "unquote_ident: rejects an unpaired backtick"
# quote_literal: single-quoted SQL string literal, Spark escape grammar.
assert_eq Spark::quote_literal("hello"), "'hello'",    "quote_literal: plain text just wrapped"
assert_eq Spark::quote_literal("it's"),  "'it\\'s'",   "quote_literal: single quote escaped"
assert_eq Spark::quote_literal("a\\b"),  "'a\\\\b'",   "quote_literal: backslash escaped"
assert_eq Spark::quote_literal("a" . chr(9) . "b"), "'a\\tb'", "quote_literal: tab → \\t"
assert_eq Spark::quote_literal(""),      "''",         "quote_literal: empty string is the empty literal"
# unquote_literal: inverse of quote_literal (decode the Spark escapes).
assert_eq Spark::unquote_literal("'hello'"),  "hello",  "unquote_literal: plain literal"
assert_eq Spark::unquote_literal("'it\\'s'"), "it's",   "unquote_literal: decodes the escaped quote"
assert_eq Spark::unquote_literal("'a\\\\b'"), "a\\b",   "unquote_literal: decodes the escaped backslash"
assert_eq Spark::unquote_literal(Spark::quote_literal("a" . chr(9) . "b")), "a" . chr(9) . "b", "unquote_literal: round-trips quote_literal through a tab"
assert_eq Spark::unquote_literal(Spark::quote_literal("café")), "café", "unquote_literal: round-trips non-ASCII"
assert_dies fn { Spark::unquote_literal("noquotes") }, "unquote_literal: rejects an unquoted value"

# build_partition_spec: Spark SQL PARTITION (...) DDL clause from ordered pairs.
assert_eq Spark::build_partition_spec([["year", 2024], ["month", 1]]), "PARTITION (year=2024, month=1)", "build_partition_spec: numeric values emitted bare"
assert_eq Spark::build_partition_spec([["region", "us-east"]]), "PARTITION (region='us-east')", "build_partition_spec: string value single-quoted"
assert_eq Spark::build_partition_spec([["region", "it's"]]), "PARTITION (region='it\\'s')", "build_partition_spec: string value escaped via quote_literal"
assert_eq Spark::build_partition_spec([["dt", 20240601], ["active"]]), "PARTITION (dt=20240601, active)", "build_partition_spec: undef value → bare dynamic-partition column"
assert_eq Spark::build_partition_spec([["weird col", "x"]]), "PARTITION (`weird col`='x')", "build_partition_spec: column quoted only when needed"
assert_dies fn { Spark::build_partition_spec("nope") }, "build_partition_spec: rejects a non-arrayref"

# escape_like: backslash-escape the Spark LIKE wildcards % _ and the escape char \.
assert_eq Spark::escape_like("plain"),  "plain",     "escape_like: plain text unchanged"
assert_eq Spark::escape_like("100%"),   "100\\%",    "escape_like: percent wildcard escaped"
assert_eq Spark::escape_like("a_b"),    "a\\_b",     "escape_like: underscore wildcard escaped"
assert_eq Spark::escape_like("a\\b"),   "a\\\\b",    "escape_like: the escape char itself is doubled"
assert_eq Spark::escape_like("50%_x"),  "50\\%\\_x", "escape_like: both wildcards in one value"

# unescape_like: inverse of escape_like — recover the literal.
assert_eq Spark::unescape_like("plain"),     "plain", "unescape_like: plain text unchanged"
assert_eq Spark::unescape_like("100\\%"),    "100%",  "unescape_like: escaped percent decodes to literal"
assert_eq Spark::unescape_like("a\\_b"),     "a_b",   "unescape_like: escaped underscore decodes to literal"
assert_eq Spark::unescape_like("a\\\\b"),    "a\\b",  "unescape_like: doubled backslash decodes to one"
assert_eq Spark::unescape_like(Spark::escape_like("50%_off\\sale")), "50%_off\\sale", "unescape_like: round-trips escape_like"
assert_dies fn { Spark::unescape_like("a%b") },    "unescape_like: rejects an unescaped wildcard"
assert_dies fn { Spark::unescape_like("trail\\") }, "unescape_like: rejects a dangling backslash"

# quote_qualified_ident: each part backtick-quoted, backtick-aware split.
assert_eq Spark::quote_qualified_ident("cat.db.my table"), "`cat`.`db`.`my table`", "quote_qualified_ident: three-level namespace"
assert_eq Spark::quote_qualified_ident("events"), "`events`", "quote_qualified_ident: bare name still backticked"
assert_dies fn { Spark::quote_qualified_ident("a.b.c.d") }, "quote_qualified_ident: rejects over-deep names"

# parse_qualified_ident: inverse of quote_qualified_ident.
assert_eq join("|", @{ Spark::parse_qualified_ident("`cat`.`my db`.`tbl`")->{parts} }), "cat|my db|tbl", "parse_qualified_ident: splits backtick-quoted parts"
assert_eq Spark::parse_qualified_ident("`db`.`weird.table`")->{parts}[1], "weird.table", "parse_qualified_ident: dot inside backticks is literal"
assert_eq Spark::parse_qualified_ident("`we``ird`")->{parts}[0], "we`ird", "parse_qualified_ident: doubled backtick decodes to one"
assert_eq Spark::parse_qualified_ident("a.b.c")->{count}, 3, "parse_qualified_ident: bare parts pass through"
# Round-trips quote_qualified_ident.
assert_eq join("|", @{ Spark::parse_qualified_ident(Spark::quote_qualified_ident("cat.db.my table"))->{parts} }), "cat|db|my table", "parse_qualified_ident: round-trips quote_qualified_ident"
assert_dies fn { Spark::parse_qualified_ident("a..b") }, "parse_qualified_ident: rejects an empty part"
assert_dies fn { Spark::parse_qualified_ident("a.b.c.d") }, "parse_qualified_ident: rejects over-deep names"

# quote_ident_if_needed: Spark quoteIfNeeded — quote only when not bare-legal.
assert_eq Spark::quote_ident_if_needed("users"), "users", "quote_ident_if_needed: bare-legal name untouched"
assert_eq Spark::quote_ident_if_needed("_tmp"),  "_tmp",  "quote_ident_if_needed: leading underscore is bare-legal"
assert_eq Spark::quote_ident_if_needed("1col"),  "`1col`", "quote_ident_if_needed: leading digit forces quoting"
assert_eq Spark::quote_ident_if_needed("my col"), "`my col`", "quote_ident_if_needed: space forces quoting"
assert_eq Spark::quote_ident_if_needed("a.b"),   "`a.b`",  "quote_ident_if_needed: dot forces quoting"

test_run
